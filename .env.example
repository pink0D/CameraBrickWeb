# MJPEG streaming server configuration.
# Copy this file to .env.local and set values to override the defaults.
#
# VITE_STREAM_HOST — hostname or IP of the streaming server.
#   Defaults to the same host the page was loaded from.
#
# VITE_STREAM_PORT — port of the streaming server.
#   Defaults to 8080.
#
# Can also be passed inline when running the dev server:
#   VITE_STREAM_HOST=192.168.1.10 VITE_STREAM_PORT=8080 npm run dev

VITE_STREAM_HOST=
VITE_STREAM_PORT=
